@using AgiliServiceDesk.Models

@{
    ViewData["Title"] = "Dashboard";

    var ultimosChamados = ViewBag.UltimosChamados as List<Chamado>;
}

<h2 class="mb-4">Dashboard</h2>

<div class="row mb-4">

    <div class="col-md-6">
        <div class="card text-bg-primary">
            <div class="card-body">
                <h5 class="card-title">Chamados</h5>
                <h2>@ViewBag.TotalChamados</h2>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card text-bg-success">
            <div class="card-body">
                <h5 class="card-title">Categorias</h5>
                <h2>@ViewBag.TotalCategorias</h2>
            </div>
        </div>
    </div>

</div>

<div class="card">

    <div class="card-header">
        Últimos Chamados
    </div>

    <div class="card-body">

        <table class="table table-hover">

            <thead>
                <tr>
                    <th>Título</th>
                    <th>Categoria</th>
                    <th>Prioridade</th>
                    <th>Data</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var chamado in ultimosChamados!)
                {
                    <tr>
                        <td>@chamado.Titulo</td>
                        <td>@chamado.Categoria?.Nome</td>
                        <td>@chamado.Prioridade</td>
                        <td>@chamado.DataAbertura.ToLocalTime().ToString("g")</td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>