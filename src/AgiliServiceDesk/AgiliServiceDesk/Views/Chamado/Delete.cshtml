@model AgiliServiceDesk.Models.Chamado

@{
    ViewData["Title"] = "Excluir Chamado";
}

<div class="mb-3">
    <h2>Excluir Chamado</h2>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">@Model.Titulo</h5>
        <p class="card-text"><strong>Categoria:</strong> @Model.Categoria?.Nome</p>
        <p class="card-text"><strong>Prioridade:</strong> @Model.Prioridade</p>
        <p class="card-text"><strong>Aberto em:</strong> @Model.DataAbertura.ToLocalTime().ToString("g")</p>
        <p class="card-text"><strong>Descrição:</strong><br />@Model.Descricao</p>

        <form asp-action="DeleteConfirmed" method="post" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirmar exclusão</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
        </form>
    </div>
</div>