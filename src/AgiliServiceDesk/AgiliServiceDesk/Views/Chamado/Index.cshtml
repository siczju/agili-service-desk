@using AgiliServiceDesk.Enums
@model IEnumerable<AgiliServiceDesk.Models.Chamado>

@{
    ViewData["Title"] = "Chamados";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Chamados</h2>

    <a asp-action="Create" class="btn btn-primary">
        Novo Chamado
    </a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Título</th>
            <th>Categoria</th>
            <th>Prioridade</th>
            <th>Status</th>
            <th>Aberto em</th>
            <th style="width:220px">Ações</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Titulo</td>
                <td>@item.Categoria?.Nome</td>
                <td>
                    @switch (item.Status)
                    {
                        case StatusChamado.Aberto:
                            <span class="badge bg-primary">Aberto</span>
                            break;

                        case StatusChamado.EmAndamento:
                            <span class="badge bg-warning text-dark">Em andamento</span>
                            break;

                        case StatusChamado.Concluido:
                            <span class="badge bg-success">Concluído</span>
                            break;
                    }
                </td>
                <td>
                    @switch (item.Status)
                    {
                        case StatusChamado.Aberto:
                            <span class="badge bg-primary">Aberto</span>
                            break;

                        case StatusChamado.EmAndamento:
                            <span class="badge bg-warning text-dark">Em andamento</span>
                            break;

                        case StatusChamado.Concluido:
                            <span class="badge bg-success">Concluído</span>
                            break;
                    }
                </td>
                <td>@item.DataAbertura.ToLocalTime().ToString("g")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>